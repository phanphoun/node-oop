{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.ts",
  "scripts": {
    "test": "node --loader ts-node/esm --test tests/endpoints.test.ts",
    "start": "node --loader ts-node/esm src/server.ts",
    "dev": "npx nodemon",
    "dev:ts": "node --loader ts-node/esm src/server.ts",
    "dev:watch": "npx nodemon",
    "build": "tsc -p tsconfig.build.json",
    "start:prod": "node dist/server.js",
    "db:migrate:run": "typeorm-ts-node-esm migration:run -d src/database/data-source.ts",
    "db:migrate:revert": "typeorm-ts-node-esm migration:revert -d src/database/data-source.ts",
    "db:migration:generate": "typeorm-ts-node-esm migration:generate -d src/database/data-source.ts",
    "db:migration:create": "typeorm-ts-node-esm migration:create"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "class-validator": "^0.15.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.3",
    "reflect-metadata": "^0.1.13"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.4.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typeorm": "^0.3.20",
    "typescript": "^5.2.2"
  }
}
