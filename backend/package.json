{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "start:ts": "npx ts-node --esm src/server.ts",
    "dev:ts": "npx ts-node --esm src/server.ts",
    "migration:run": "npm run db:migrate:run",
    "migration:revert": "npm run db:migrate:revert",
    "db:migrate:run": "node --loader ts-node/esm ./node_modules/typeorm/cli.js migration:run -d src/database/data-source.ts",
    "db:migrate:revert": "node --loader ts-node/esm ./node_modules/typeorm/cli.js migration:revert -d src/database/data-source.ts",
    "db:migration:create": "node --loader ts-node/esm ./node_modules/typeorm/cli.js migration:create src/database/migrations/$npm_config_name -d src/database/data-source.ts",
    "db:migration:generate": "node --loader ts-node/esm ./node_modules/typeorm/cli.js migration:generate src/database/migrations/$npm_config_name -d src/database/data-source.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "class-validator": "^0.15.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.3",
    "reflect-metadata": "^0.1.14",
    "typeorm": "^0.3.30"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.41",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.9.3"
  }
}
